#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_APP_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
APP_DIR="${OPENCLAW_GATEWAY_APP_DIR:-$DEFAULT_APP_DIR}"
ENV_FILE="${APP_DIR}/.env"
SERVICE_NAME="${OPENCLAW_GATEWAY_COMPOSE_SERVICE:-openclaw-gateway}"
CONTAINER_NAME="${OPENCLAW_GATEWAY_CONTAINER:-openclaw-gateway-bastion}"
CUSTOM_IMAGE_REPO="${OPENCLAW_GATEWAY_IMAGE_REPO:-openclaw-gateway-bastion}"
BASE_IMAGE="${OPENCLAW_BASE_IMAGE:-ghcr.io/openclaw/openclaw}"
DEFAULT_TAG="2026.5.2"
HEALTH_TIMEOUT_SECONDS="${OPENCLAW_GATEWAY_HEALTH_TIMEOUT_SECONDS:-240}"
GATEWAY_PORT="${OPENCLAW_GATEWAY_PORT:-18789}"
ROLLBACK_NEEDED=0
ROLLBACK_RUNNING=0
ROLLBACK_OLD_TAG=""
ROLLBACK_PREVIOUS_REF=""

export PATH="/home/opc/bin:/home/opc/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin:${PATH:-}"

log() {
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')" "$*"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    log "missing required command: $1"
    exit 1
  }
}

current_tag() {
  if [ -f "$ENV_FILE" ]; then
    awk -F= '/^OPENCLAW_BASE_IMAGE_TAG=/ { print $2; found=1 } END { exit found ? 0 : 1 }' "$ENV_FILE" 2>/dev/null || true
  fi
}

env_value() {
  local key="$1"
  if [ -f "$ENV_FILE" ]; then
    awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; found=1 } END { exit found ? 0 : 1 }' "$ENV_FILE" 2>/dev/null || true
  fi
}

set_env_var() {
  local key="$1"
  local value="$2"
  touch "$ENV_FILE"
  if grep -q "^${key}=" "$ENV_FILE"; then
    sed -i.bak -E "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    rm -f "${ENV_FILE}.bak"
  else
    printf '%s=%s\n' "$key" "$value" >>"$ENV_FILE"
  fi
}

restore_previous_gateway() {
  local failed_status=$?

  if [ "$ROLLBACK_NEEDED" != "1" ] || [ "$ROLLBACK_RUNNING" = "1" ]; then
    exit "$failed_status"
  fi

  ROLLBACK_RUNNING=1
  log "update failed; restoring previous gateway tag ${ROLLBACK_OLD_TAG:-unknown}"

  set +e
  if [ -n "$ROLLBACK_OLD_TAG" ]; then
    set_env_var OPENCLAW_BASE_IMAGE "$BASE_IMAGE"
    set_env_var OPENCLAW_BASE_IMAGE_TAG "$ROLLBACK_OLD_TAG"
    set_env_var OPENCLAW_GATEWAY_IMAGE_REPO "$CUSTOM_IMAGE_REPO"

    docker compose build "$SERVICE_NAME"
    docker compose up -d --force-recreate "$SERVICE_NAME"
    wait_for_gateway
    docker exec "$CONTAINER_NAME" bastion-run true
    verify_gateway_http
    local rollback_status=$?

    if [ "$rollback_status" -eq 0 ]; then
      log "rollback completed: restored ${ROLLBACK_PREVIOUS_REF:-${CUSTOM_IMAGE_REPO}:${ROLLBACK_OLD_TAG}}"
    else
      log "rollback failed; manual intervention required for ${CONTAINER_NAME}"
    fi
  else
    log "rollback skipped: previous tag is unknown"
  fi

  exit "$failed_status"
}

cleanup_old_images() {
  local latest_tag="$1"
  local new_ref="$2"
  local old_custom_refs old_base_refs

  old_custom_refs="$(docker images "$CUSTOM_IMAGE_REPO" --format '{{.Repository}}:{{.Tag}}' | awk -v keep="$new_ref" '$0 != keep { print }')"
  if [ -n "$old_custom_refs" ]; then
    log "removing old custom images"
    printf '%s\n' "$old_custom_refs" | xargs -r docker image rm || true
  fi

  old_base_refs="$(docker images "$BASE_IMAGE" --format '{{.Repository}}:{{.Tag}}' | awk -v keep="${BASE_IMAGE}:${latest_tag}" '$0 != keep { print }')"
  if [ -n "$old_base_refs" ]; then
    log "removing old official base image tags"
    printf '%s\n' "$old_base_refs" | xargs -r docker image rm || true
  fi

  docker image prune -f >/dev/null || true
}

latest_stable_tag() {
  local tmpdir token url headers body next
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  token="$(curl -fsSL "https://ghcr.io/token?service=ghcr.io&scope=repository:openclaw/openclaw:pull" | jq -r '.token')"
  url="https://ghcr.io/v2/openclaw/openclaw/tags/list?n=1000"

  while [ -n "$url" ]; do
    headers="${tmpdir}/headers"
    body="${tmpdir}/body"
    curl -fsSL -D "$headers" -o "$body" -H "Authorization: Bearer ${token}" "$url"
    jq -r '.tags[]?' "$body" >>"${tmpdir}/tags"

    next="$(awk -F'[<>]' 'tolower($0) ~ /rel="next"/ { print $2 }' "$headers" | tail -n 1)"
    case "$next" in
      http*) url="$next" ;;
      /*) url="https://ghcr.io${next}" ;;
      *) url="" ;;
    esac
  done

  jq -Rr 'select(test("^[0-9]+\\.[0-9]+\\.[0-9]+$"))' "${tmpdir}/tags" | sort -V | tail -n 1
}

wait_for_gateway() {
  local deadline status health
  deadline=$((SECONDS + HEALTH_TIMEOUT_SECONDS))

  while [ "$SECONDS" -lt "$deadline" ]; do
    status="$(docker inspect -f '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true)"
    health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}no-health{{end}}' "$CONTAINER_NAME" 2>/dev/null || true)"

    if [ "$status" = "running" ] && { [ "$health" = "healthy" ] || [ "$health" = "no-health" ]; }; then
      return 0
    fi
    sleep 5
  done

  docker ps --filter "name=${CONTAINER_NAME}" --format 'container={{.Names}} status={{.Status}} image={{.Image}}' || true
  docker logs --tail 120 "$CONTAINER_NAME" || true
  log "gateway did not become healthy within ${HEALTH_TIMEOUT_SECONDS}s"
  return 1
}

verify_gateway_http() {
  docker exec "$CONTAINER_NAME" node -e "
    fetch('http://127.0.0.1:${GATEWAY_PORT}/healthz')
      .then((res) => process.exit(res.ok ? 0 : 1))
      .catch(() => process.exit(1));
  "
}

verify_discord_plugin() {
  docker exec "$CONTAINER_NAME" sh -lc '
    openclaw plugins list --json 2>/tmp/openclaw-discord-verify-warnings \
      | grep -Eq "\"id\"[[:space:]]*:[[:space:]]*\"discord\""
  '
}

main() {
  require_cmd curl
  require_cmd docker
  require_cmd jq

  cd "$APP_DIR"

  local old_tag latest_tag previous_ref new_ref gateway_token
  old_tag="$(current_tag)"
  old_tag="${old_tag:-$DEFAULT_TAG}"
  latest_tag="$(latest_stable_tag)"
  gateway_token="$(env_value OPENCLAW_GATEWAY_TOKEN)"

  if [ -z "$latest_tag" ]; then
    log "could not determine latest stable tag for ${BASE_IMAGE}"
    exit 1
  fi

  if [ -z "$gateway_token" ]; then
    log "OPENCLAW_GATEWAY_TOKEN is missing from ${ENV_FILE}"
    exit 1
  fi

  log "current configured tag: ${old_tag}"
  log "latest stable official tag: ${latest_tag}"

  if [ "$old_tag" = "$latest_tag" ]; then
    log "already on latest tag; rebuilding configured gateway image and verifying"
    set_env_var OPENCLAW_BASE_IMAGE "$BASE_IMAGE"
    set_env_var OPENCLAW_BASE_IMAGE_TAG "$latest_tag"
    set_env_var OPENCLAW_GATEWAY_IMAGE_REPO "$CUSTOM_IMAGE_REPO"
    docker compose build --pull "$SERVICE_NAME"
    docker compose up -d --force-recreate "$SERVICE_NAME"
    wait_for_gateway
    docker exec "$CONTAINER_NAME" bastion-run true
    verify_gateway_http
    verify_discord_plugin
    log "gateway is healthy and Discord plugin is available"
    exit 0
  fi

  previous_ref="$(docker inspect -f '{{.Config.Image}}' "$CONTAINER_NAME" 2>/dev/null || true)"
  new_ref="${CUSTOM_IMAGE_REPO}:${latest_tag}"
  ROLLBACK_OLD_TAG="$old_tag"
  ROLLBACK_PREVIOUS_REF="$previous_ref"

  log "updating ${CUSTOM_IMAGE_REPO} from ${old_tag} to ${latest_tag}"
  docker manifest inspect "${BASE_IMAGE}:${latest_tag}" >/dev/null
  docker pull "${BASE_IMAGE}:${latest_tag}"

  trap restore_previous_gateway ERR
  ROLLBACK_NEEDED=1

  set_env_var OPENCLAW_BASE_IMAGE "$BASE_IMAGE"
  set_env_var OPENCLAW_BASE_IMAGE_TAG "$latest_tag"
  set_env_var OPENCLAW_GATEWAY_IMAGE_REPO "$CUSTOM_IMAGE_REPO"

  docker compose build --pull "$SERVICE_NAME"
  docker compose up -d --force-recreate "$SERVICE_NAME"
  wait_for_gateway

  docker exec "$CONTAINER_NAME" bastion-run true
  verify_gateway_http

  ROLLBACK_NEEDED=0
  trap - ERR

  cleanup_old_images "$latest_tag" "$new_ref"

  log "update completed: ${previous_ref:-unknown} -> ${new_ref}"
}

main "$@"
